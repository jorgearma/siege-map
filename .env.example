# SSH Bot Rain Map - Environment Configuration

# Path to SSH log file (common locations)
# Debian/Ubuntu: /var/log/auth.log
# RHEL/CentOS:   /var/log/secure
SSH_LOG_PATH=/var/log/auth.log
NGINX_LOG_PATH=/var/log/nginx/access.log

# Your VPS coordinates (where the "rain" falls to)
VPS_LAT=40.4168
VPS_LON=-3.7038
VPS_LABEL=My VPS

# Geolocation provider: "ip-api" (free, no key) or "ipinfo" (needs token)
GEO_PROVIDER=ip-api

# Only needed if GEO_PROVIDER=ipinfo
IPINFO_TOKEN=

# Backend host/port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend port
FRONTEND_PORT=3000

# Max events to keep in memory
MAX_EVENTS=10000

# Geolocation cache TTL in seconds
GEO_CACHE_TTL=86400

# WebSocket broadcast interval in seconds (aggregation window)
WS_BROADCAST_INTERVAL=1.0

# Threat intelligence (Phase 3)
# AbuseIPDB: free tier = 1000 checks/day — https://www.abuseipdb.com/
ABUSEIPDB_API_KEY=

# Shodan: optional host info (ports, OS, vulns) — https://www.shodan.io/
SHODAN_API_KEY=

# AbuseIPDB result cache TTL in seconds
ABUSE_CACHE_TTL=86400
